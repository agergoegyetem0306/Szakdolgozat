@article{Diener1985,
	title = {The {Satisfaction} {With} {Life} {Scale}},
	volume = {49},
	issn = {0022-3891},
	url = {http://www.tandfonline.com/doi/abs/10.1207/s15327752jpa4901_13},
	doi = {10.1207/s15327752jpa4901_13},
	abstract = {This article reports the development and validation of a scale to measure global life satisfaction, the Satisfaction With Life Scale (SWLS). Among the various components of subjective well-being, the SWLS is narrowly focused to assess global life satisfaction and does not tap related constructs such as positive affect or loneliness. The SWLS is shown to have favorable psychometric properties, including high internal consistency and high temporal reliability. Scores on the SWLS correlate moderately to highly with other measures of subjective well-being, and correlate predictably with specific personality characteristics. It is noted that the SWLS is suited for use with different age groups, and other potential uses ofthe scale are discussed. © 1985, Taylor \& Francis Group, LLC. All rights reserved.},
