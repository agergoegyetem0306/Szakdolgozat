@article{Meijman1988,
	title = {The evaluation of the {Groningen} {Sleep} {Quality} {Scale}},
	abstract = {The Groningen Sleep Quality Scale has been evaluated with respect to its scaling characteristics. Two versions of the scale are studied. the one version measuring the specific sleep quality during one night, the other version measuring the general sleep quality during a period of one month. Both versions fit very well in the one-dimensional scaling model proposed by Mokken. The scaling structure of both versions is invariant with respect to the characteristics of the respondent as well as with respect to the characteristics of the conditions of sleep. Thus both versions measure the same underlying concept - sleep quality - under very different conditions of measurement. Tentative norms have been established in both versions of the scale},
	journal = {Groningen: Heymans Bulletin (HB 88—13—EX)},
	author = {Meijman, T. F. and De Vries-Griever, A. H. and De Vries, G.},
	year = {1988},
}

