}

@article{Khakpour2021,
	title = {Convergence of {Gamification} and {Machine} {Learning}: {A} {Systematic} {Literature} {Review}},
	volume = {26},
	issn = {22111670},
	url = {https://link.springer.com/article/10.1007/s10758-020-09456-4},
	doi = {10.1007/S10758-020-09456-4/TABLES/8},
	abstract = {Recent developments in human–computer interaction technologies raised the attention towards gamification techniques, that can be defined as using game elements in a non-gaming context. Furthermore, advancement in machine learning (ML) methods and its potential to enhance other technologies, resulted in the inception of a new era where ML and gamification are combined. This new direction thrilled us to conduct a systematic literature review in order to investigate the current literature in the field, to explore the convergence of these two technologies, highlighting their influence on one another, and the reported benefits and challenges. The results of the study reflect the various usage of this confluence, mainly in, learning and educational activities, personalizing gamification to the users, behavioral change efforts, adapting the gamification context and optimizing the gamification tasks. Adding to that, data collection for machine learning by gamification technology and teaching machine learning with the help of gamification were identified. Finally, we point out their benefits and challenges towards streamlining future research endeavors.},
	number = {3},
	urldate = {2022-01-12},
	journal = {Technology, Knowledge and Learning},
	publisher = {Springer Science and Business Media B.V.},
	author = {Khakpour, Alireza and Colomo-Palacios, Ricardo},
	month = sep,
	year = {2021},
	keywords = {Gamification, Learning, Personalization, Behavioral change, Machine learning, Systematic literature review},
	pages = {597--636},
	file = {PDF:files/1693/full-text.pdf:application/pdf},
}

@article{AnilYasin2021,
	title = {Role of gamification in engineering education: {A} systematic literature review},
	volume = {2021-April},
	issn = {21659567},
	doi = {10.1109/EDUCON46332.2021.9454038},
	abstract = {This systematic review leverages 'Preferred Reporting Items for Systematic Reviews and Meta-Analyses' (PRISMA) method as a way to evaluate and map the state of the art of gamification strategies that are used in engineering studies. This research will correspond to the following research questions; (1) are there any commonly used techniques of gamification in engineering education? (2) What are the state-of-the-art practices in engineering education in terms of gamification? (3) Is gamification a useful teaching strategy in engineering education? Through answering these questions, the study offers insight to the lecturers on adapting current gamification techniques, efficient and effective way of utilizing this education strategy, and provide further research venues for future academic endowers.},
	urldate = {2022-01-12},
