@article{Martos2014,
	title = {Az Élettel való {Elégedettség} {Skála} magyar változatának ({SWLS}-{H}) pszichometriai jellemzoi},
	volume = {15},
	issn = {17863759},
	url = {http://internal.psychology.illinois.edu/~ediener/SWLS.html},
	doi = {10.1556/Mental.15.2014.3.9},
	abstract = {Background: The Satisfaction with Life Scale (Diener, Emmons, Larsen, \& Griffin, 1985) is one of the most frequently applied measures in well-being research. Aim: In the present study, we present the revised Hungarian version of the Satisfaction with Life Scale (SWLS-H) and its psychometric characteristics. Method: Data from eight cross-sectional questionnaire studies (N = 3805, 1547 male, 2253 female) were used. Along with SWLS-H we administered the Rosenberg Self-esteem Scale, the Purpose in Life Test (PIL), and the Meaning in Life Questionnaire (MLQ). In a subsample, we also assessed the EPQ Lie Scale to control for social desirability, and asked ratings for self-rated health and subjective financial status as well. Results: Confirmatory factor analysis provided evidence for a unidmensional structure of the SWLS-H and the invariance of the factor loadings between subsamples. Internal consistency (all Cronbach's alphas above 0.84) and test - retest stability were excellent. Level of life satisfaction was somewhat lower for elder age groups and the strongest predictor of life satisfaction was subjective financial status (beta = 0.304). SWLS-H score correlated only marginally with EPQ-L score, but it was associated with meaning in life (PIL: r = 0.549, MLQ: r = 0.395) and self-esteem (r = 0.429). Moreover, it predicted self-rated health positively (beta = 0.219) and independently from presence of meaning in life and self-esteem. Conclusions: The results indicate that the Hungarian version of the Satisfaction with Life Scale is a reliable and valid measure for assessing the subjective experience of life satisfaction.},
	number = {3},
	urldate = {2019-12-04},
	journal = {Mentalhigiene es Pszichoszomatika},
	author = {Martos, Tamás and Sallay, Viola and Désfalvi, Judit and Szabó, Tünde and Ittzés, András},
	year = {2014},
	keywords = {reliability, validity, confirmative factor analysis, Élettel való Elégedettség Skála, érvényesség, konfirmatív faktorelemzés, Kulcsszavak: elégedettség, megbízhatóság, satisfaction, Satisfaction with Life Scale},
	pages = {289--303},
	file = {swls_magyar.pdf:C\:\\Users\\abarik\\Zotero\\storage\\WAZXIC7E\\swls_magyar.pdf:application/pdf;Tamás et al. - 2014 - Az Élettel való Elégedettség Skála magyar változatának (SWLS-H) pszichometriai jellemzõi.pdf:files/1756/Tamás et al. - 2014 - Az Élettel való Elégedettség Skála magyar változatának (SWLS-H) pszichometriai jellemzõi.pdf:application/pdf},
}

