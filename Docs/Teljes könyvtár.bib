@article{Schredl2011,
	title = {Frequency of {Lucid} {Dreaming} in a {Representative} {German} {Sample}},
	volume = {112},
	issn = {0031-5125},
	doi = {10.2466/09.pms.112.1.104-108},
	abstract = {The term lucid dream designates a dream in which the dreamer – while dreaming – is aware that he is dreaming. In a representative sample (N = 919), 51\% of the participants reported that they have experienced a lucid dream at least once. The effect of age and sex on lucid dream frequency might be explained by dream recall frequency. Other sociodemographic variables like education, marital status or monthly income were not related to lucid dream frequency. Given the relatively high prevalence of lucid dreaming reported in the present study, research on lucid dreams might be pursued in the sleep laboratory to expand the knowledge about sleep, dreaming, and consciousness processes in general.},
