@incollection{Kaplan2013,
	address = {New York, NY, US},
	title = {Measurement of emotions.},
	isbn = {978-0-415-87932-3 (Hardcover); 978-0-203-09524-9 (PDF)},
	abstract = {Work is an emotional experience. Employees experience fear over losing their jobs, anger over being treated unfairly, and anxiety about impending deadlines. However, they also derive warmth and gratitude when interacting with coworkers, pride from working for a virtuous organization, and a sense of personal growth from job accomplishments. Mixed in with these experiences are the emotions that individuals bring with them to work, such as distress about a family member's illness, frustration over morning traffic, or underlying psychopathological issues that cannot simply "be left at the company's door." Collectively, these numerous and varied emotions have significant implications for employees' physical and psychological well-being and for their ability to function effectively at work. Given the consequences of these workplace emotions, their assessment is an important endeavor, both for scholarly and applied purposes. Thus, the goal of this chapter is to provide an overview of the strategies available for assessing work-related emotions and to offer practical guidance for those engaged in such practice. Below, we first mention general considerations regarding the measurement of emotions and then discuss specific measurement strategies. (PsycInfo Database Record (c) 2020 APA, all rights reserved)},
	booktitle = {Research methods in occupational health psychology: {Measurement}, design, and data analysis.},
	publisher = {Routledge/Taylor \& Francis Group},
	author = {Kaplan, Seth and Dalal, Reeshad S and Luchman, Joseph N},
	editor = {Sinclair, R. R. and Wang, M. and Tetrick, L. E.},
	year = {2013},
	keywords = {*Attitude Measures, *Emotions, *Employee Attitudes, *Employee Characteristics, Employee Efficiency, Mental Health},
	pages = {61--75},
}

